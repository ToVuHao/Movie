<%- include('../partial/header') %>

<div class="container" style="min-height: 60vh;">
    <h2 style="margin-top: 20px;">🔍 Kết quả tìm kiếm cho: <span style="color: #e50914;">"<%= keyword %>"</span></h2>
    
    <div class="movie-grid" style="margin-top: 20px;">
        <% if (movies && movies.length > 0) { %>
            <% movies.forEach(movie => { %>
                <div class="movie-card">
                    <a href="/movie/<%= movie._id %>" style="text-decoration: none; color: inherit;">
                        <img src="<%= movie.thumbnail || 'https://via.placeholder.com/200x300?text=No+Image' %>" alt="<%= movie.title %>">
                        <h3><%= movie.title %></h3>
                    </a>
                    <p>👁️ <%= movie.views %> lượt xem</p>
                </div>
            <% }) %>
        <% } else { %>
            <div style="grid-column: 1 / -1; text-align: center; padding: 50px; background: white; border-radius: 8px;">
                <h3 style="color: #666;">Rất tiếc, không tìm thấy bộ phim nào phù hợp.</h3>
                <p>Hãy thử tìm kiếm bằng một từ khóa khác nhé!</p>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partial/footer') %>